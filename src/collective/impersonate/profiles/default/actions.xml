<?xml version="1.0" encoding="utf-8"?>
<object xmlns:i18n="http://xml.zope.org/namespaces/i18n"
        meta_type="Plone Actions Tool"
        name="portal_actions"
>
  <object meta_type="CMF Action Category"
          name="user"
  >
    <object insert-before="logout"
            meta_type="CMF Action"
            name="impersonate"
            i18n:domain="plone"
    >
      <property name="title"
                i18n:translate=""
      >Impersonate</property>
      <property name="url_expr">string:${globals_view/navigationRootUrl}/@@impersonate</property>
      <property name="link_target" />
      <property name="icon_expr">string:people</property>
      <property name="permissions">
        <element value="Manage Site" />
      </property>
      <property name="visible">True</property>
    </object>
  </object>
</object>
